# Prisma Postgres (Vercel) — se obtienen al conectar la DB en el dashboard
PRISMA_DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=XXXX"
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Vercel Blob — se obtiene al crear el store en el dashboard de Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXX"


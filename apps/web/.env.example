# Vercel Postgres — se obtienen automáticamente al conectar la DB en el dashboard de Vercel
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Vercel Blob — se obtiene al crear el store en el dashboard de Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXX"

